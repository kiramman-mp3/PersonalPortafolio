// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Services {
  id           String   @id @default(uuid())
  title        String   @db.VarChar(100)
  description  String   @db.Text
  imageUrl     String   @db.Text
  imageAlt     String   @db.VarChar(100)
  extendedInfo String[] @db.VarChar(255)
  technologies String[] @db.VarChar(255)
}

model Projects {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(100)
  description  String   @db.Text
  technologies String[] @db.VarChar(255)
  status       String   @db.VarChar(50) // 'completado' | 'en-progreso' | 'planificado'
  image        String   @db.Text
  githubUrl    String?  @db.VarChar(255)
  webUrl       String?  @db.VarChar(255)
  backendUrl   String?  @db.VarChar(255)
  apkUrl       String?  @db.VarChar(255)
}

model Contacts {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  email     String   @db.VarChar(150)
  subject   String?  @db.VarChar(150)
  message   String   @db.Text
  createdAt DateTime @default(now())
}
