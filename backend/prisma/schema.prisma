// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Blogs {
  id            Int      @id @default(autoincrement())
  authors       String[] @db.VarChar(255)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  title         String   @db.VarChar(100)
  urls          String[] @db.VarChar(100)
  description   String   @db.Text
  tags          String[] @db.VarChar(255)
  image         String   @default("")
  imagePublicId String   @default("")
}

model Services {
  id           String   @id @default(uuid())
  title        String   @db.VarChar(100)
  description  String   @db.Text
  imageUrl     String   @db.VarChar(255)
  imageAlt     String   @db.VarChar(100)
  extendedInfo String[] @db.VarChar(255)
  technologies String[] @db.VarChar(255)
}

model Projects {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(100)
  description  String   @db.Text
  technologies String[] @db.VarChar(255)
  status       String   @db.VarChar(50) // 'completado' | 'en-progreso' | 'planificado'
  image        String   @db.VarChar(255)
  githubUrl    String   @db.VarChar(255)
}
